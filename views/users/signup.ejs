<%-layout("../layouts/boilerplate.ejs")%>
<body>
    <br>
    <div class="row col-8 offset-2">
    <h3>Sign Up</h3>
    <form action="/signup/new" method="post" class="needs-validation" novalidate>
    <div><label for="username" class="form-label">Username</label>
    <input type="text" name="username" id="username" class="form-control"  required>
    <div class="valid-feedback">Username is available.</div>
    <div class="invalid-feedback">Please enter a proper username.</div>
    <br></div>
    <div><label for="email" class="form-label">Email</label>
    <input type="email" name="email" id="email" class="form-control"  required>
    <div class="valid-feedback">Email validated.</div>
    <div class="invalid-feedback">Please enter a proper email.</div>
    <br></div>
    <div><label for="password" class="form-label">Password</label>
    <input type="password" name="password" id="password" class="form-control"  required>
    <div class="valid-feedback">Password is strong.</div>
    <div class="invalid-feedback">Please enter a strong and valid password.</div><br></div>
    <button class="btn btn-success">Signup</button>
    </form>
    </div>
    </body>